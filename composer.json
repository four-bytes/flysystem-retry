{
    "name": "four-bytes/flysystem-retry",
    "description": "Flysystem v3 retry decorator for any FilesystemAdapter",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Four Bytes",
            "email": "info@four-bytes.de"
        }
    ],
    "require": {
        "php": ">=8.2",
        "league/flysystem": "^3.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "league/flysystem-memory": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Four\\Flysystem\\Retry\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Four\\Flysystem\\Retry\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
